# =============================================================================
# .gitignore — Hidden Entrepreneur Detection Pipeline
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/

# --- Virtual environment ---
.venv/

# --- Data files (large, not tracked) ---
*.parquet

# --- Output artefacts (regenerated by running the pipeline) ---
output/

# --- CatBoost training logs ---
catboost_info/

# --- Jupyter ---
.ipynb_checkpoints/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
Thumbs.db
.DS_Store

# --- Scratch / investigation scripts ---
investigate.py